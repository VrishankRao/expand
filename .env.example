# XPAND Local Environment Configuration Example
DEBUG=True
SECRET_KEY=django-insecure-your-secret-key-goes-here

# Supabase PostgreSQL Connection URL
DATABASE_URL=postgresql://postgres.xxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Redis Cache Connection URL
REDIS_URL=redis://localhost:6379/0

# MSG91 Configuration (SMS OTP)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_otp_template_id

# AWS SES Configuration (Email Notifications)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION_NAME=us-east-1
AWS_SES_SENDER=sender@xpand.so
